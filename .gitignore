# Work product — local only, never pushed to GitHub
# Each agent's inbox, outputs, and archive stay on the designer's machine

agents/ux-review/inbox/*
agents/ux-review/outputs/*
agents/ux-review/archive/*

# Keep the folders themselves (empty placeholder)
!agents/ux-review/inbox/.gitkeep
!agents/ux-review/outputs/.gitkeep
!agents/ux-review/archive/.gitkeep

# Adding a new agent? Copy the three lines above and update the path.
# Example:
# agents/content-review/inbox/*
# agents/content-review/outputs/*
# agents/content-review/archive/*

# OS
.DS_Store
Thumbs.db
